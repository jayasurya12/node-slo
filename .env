# Datadog APM settings
DD_SERVICE=Node_SLO
DD_ENV=dev
DD_VERSION=1.0.0
DD_TRACE_SAMPLE_RATE=1                            # ✅ Ensure full tracing
DD_TRACE_AGENT_HOSTNAME=localhost                 # ✅ Address where Datadog Agent is running
DD_TRACE_AGENT_PORT=8126                          # ✅ Default Datadog Agent APM port
# DD_TRACE_IGNORED_OUTGOING_HOSTS=httpbin.org     # ❌ Remove or comment to trace httpbin

# App settings
PORT=3000



